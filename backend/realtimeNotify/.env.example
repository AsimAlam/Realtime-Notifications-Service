
# Copy this file to .env locally and fill real values there.

POSTGRES_USER=postgres           # example placeholder
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD
POSTGRES_DB=realtime
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

SPRING_PROFILES_ACTIVE=dev

# change this to a strong secret for JWT signing in production
JWT_SECRET=REPLACE_JWT_SECRET